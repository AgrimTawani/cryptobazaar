generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum OnboardingStatus {
  REGISTERED
  KYC_PENDING
  KYC_PASSED
  EDD_PENDING
  EDD_PASSED
  INTERVIEW_PENDING
  VERIFIED_MEMBER
  REJECTED
}

enum OnboardingLayer {
  KYC
  EDD
  INTERVIEW
}

enum OnboardingLayerStatus {
  PENDING
  IN_PROGRESS
  PASSED
  FAILED
}

enum SubscriptionTier {
  STARTER
  TRADER
  PRO
}

model User {
  id                    String            @id @default(uuid())
  walletAddress         String            @unique @map("wallet_address")
  did                   String?           @unique
  onboardingStatus      OnboardingStatus  @default(REGISTERED) @map("onboarding_status")
  subscriptionTier      SubscriptionTier? @map("subscription_tier")
  subscriptionExpiresAt DateTime?         @map("subscription_expires_at")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  onboardingRecords     OnboardingRecord[]

  @@map("users")
}

model OnboardingRecord {
  id              String                @id @default(uuid())
  userId          String                @map("user_id")
  layer           OnboardingLayer
  status          OnboardingLayerStatus @default(PENDING)
  result          Json?
  rejectionReason String?               @map("rejection_reason")
  vcCredentialId  String?               @map("vc_credential_id")
  reapplyAfter    DateTime?             @map("reapply_after")
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")
  user            User                  @relation(fields: [userId], references: [id])

  @@map("onboarding_records")
}
